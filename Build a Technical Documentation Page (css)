body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  line-height: 1.6;
  color: #333;
  margin: 0;
  padding: 0;
  display: flex;
}

#navbar {
  position: fixed;
  width: 280px;
  height: 100vh;
  border-right: 2px solid #eceff1;
  background-color: #f8f9fa;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

#navbar header {
  font-size: 1.4rem;
  font-weight: bold;
  padding: 20px;
  color: #2c3e50;
  border-bottom: 1px solid #eceff1;
}

.nav-link {
  padding: 15px 20px;
  text-decoration: none;
  color: #546e7a;
  border-bottom: 1px solid #eceff1;
  transition: all 0.2s ease;
}

.nav-link:hover {
  background-color: #e9ecef;
  color: #2c3e50;
  padding-left: 25px;
}

#main-doc {
  margin-left: 300px;
  padding: 40px;
  max-width: 800px;
}

.main-section {
  margin-bottom: 60px;
}

.main-section header {
  font-size: 1.8rem;
  color: #2c3e50;
  margin-bottom: 15px;
  font-weight: 600;
}

p {
  margin-bottom: 15px;
  color: #555;
}

code {
  display: block;
  background-color: #f1f3f5;
  border-left: 4px solid #3776ab;
  padding: 15px;
  font-family: 'Courier New', Courier, monospace;
  font-size: 0.95rem;
  border-radius: 4px;
  margin: 15px 0;
  white-space: pre-line;
}

ul {
  padding-left: 20px;
  margin-bottom: 20px;
}

li {
  margin-bottom: 10px;
}

@media (max-width: 768px) {
  body {
    flex-direction: column;
  }

  #navbar {
    position: relative;
    width: 100%;
    height: auto;
    border-right: none;
    border-bottom: 2px solid #eceff1;
  }

  #navbar header {
    text-align: center;
  }

  #main-doc {
    margin-left: 0;
    padding: 20px;
  }
}
